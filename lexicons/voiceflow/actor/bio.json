{
  "lexicon": 1,
  "id": "voiceflow.actor.bio",
  "type": "record",
  "description": "A voice-based bio for VoiceFlow profiles.",
  "record": {
    "type": "object",
    "required": ["bioBlob", "duration", "createdAt"],
    "properties": {
      "bioBlob": { "type": "blob" },
      "duration": { "type": "integer", "minimum": 0 },
      "transcript": { "type": "string", "maxLength": 5000 },
      "createdAt": { "type": "string", "format": "datetime" }
    }
  }
}
