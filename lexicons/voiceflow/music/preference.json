{
  "lexicon": 1,
  "id": "voiceflow.music.preference",
  "type": "record",
  "description": "Music preferences for VoiceFlow matchmaking and discovery.",
  "record": {
    "type": "object",
    "required": ["updatedAt"],
    "properties": {
      "favoriteSongs": {
        "type": "array",
        "items": {
          "type": "object",
          "required": ["title", "artist", "platform"],
          "properties": {
            "title": { "type": "string", "maxLength": 256 },
            "artist": { "type": "string", "maxLength": 256 },
            "platform": {
              "type": "string",
              "enum": ["spotify", "appleMusic", "youtubeMusic", "other"]
            },
            "platformUrl": { "type": "string", "maxLength": 2048 },
            "externalId": { "type": "string", "maxLength": 256 }
          }
        }
      },
      "favoriteGenres": {
        "type": "array",
        "items": { "type": "string", "maxLength": 64 }
      },
      "updatedAt": { "type": "string", "format": "datetime" }
    }
  }
}
